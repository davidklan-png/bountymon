---
interface Props {
  totalBounty: number;
  liveCount: number;
  inProgressCount: number;
  plannedCount: number;
  annualSavings: number;
}

const { totalBounty, liveCount, inProgressCount, plannedCount, annualSavings } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
  <div class="bg-gradient-to-br from-green-600/20 to-green-800/20 border border-green-600/30 rounded-lg p-4">
    <p class="text-sm text-green-400 font-medium">Total Bounty</p>
    <p class="text-3xl font-bold text-white">${totalBounty.toLocaleString()}</p>
  </div>
  <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-4">
    <p class="text-sm text-gray-400 font-medium">Annual Savings</p>
    <p class="text-3xl font-bold text-white">${annualSavings.toLocaleString()}</p>
  </div>
  <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-4">
    <p class="text-sm text-gray-400 font-medium">✅ Live</p>
    <p class="text-3xl font-bold text-green-400">{liveCount}</p>
  </div>
  <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-4">
    <p class="text-sm text-gray-400 font-medium">🔄 In Progress</p>
    <p class="text-3xl font-bold text-yellow-400">{inProgressCount}</p>
  </div>
  <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-4">
    <p class="text-sm text-gray-400 font-medium">📋 Planned</p>
    <p class="text-3xl font-bold text-blue-400">{plannedCount}</p>
  </div>
</div>
