---
interface Props {
  maturity: string;
}

const { maturity } = Astro.props;

const config: Record<string, { color: string; bg: string }> = {
  'early': { color: 'text-orange-400', bg: 'bg-orange-500/10 border-orange-500/20' },
  'growing': { color: 'text-yellow-400', bg: 'bg-yellow-500/10 border-yellow-500/20' },
  'stable': { color: 'text-blue-400', bg: 'bg-blue-500/10 border-blue-500/20' },
  'mature': { color: 'text-green-400', bg: 'bg-green-500/10 border-green-500/20' },
};

const c = config[maturity] || { color: 'text-gray-400', bg: 'bg-gray-500/10 border-gray-500/20' };
---

<span class:list={['inline-flex items-center rounded-full border text-xs px-2 py-0.5 font-medium', c.color, c.bg]}>
  {maturity.charAt(0).toUpperCase() + maturity.slice(1)}
</span>
