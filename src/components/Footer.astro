<footer class="border-t border-gray-800 bg-gray-950 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-3">
          <img src="/mascot.png" alt="" class="w-8 h-8 object-contain" />
          <span class="text-lg font-bold text-white">Bountymon</span>
        </div>
        <p class="text-gray-400 text-sm max-w-md">
          A community directory and bounty marketplace for replacing moat-driven enterprise software with vibe-coded alternatives. This site is itself vibe-coded.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white mb-3">Browse</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/directory" class="text-gray-400 hover:text-white transition-colors">Directory</a></li>
          <li><a href="/bounties" class="text-gray-400 hover:text-white transition-colors">Bounty Board</a></li>
          <li><a href="/calculator" class="text-gray-400 hover:text-white transition-colors">Savings Calculator</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white mb-3">Community</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/manifesto" class="text-gray-400 hover:text-white transition-colors">Manifesto</a></li>
          <li><a href="https://github.com/davidklan-png/bountymon" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://github.com/davidklan-png/bountymon/blob/main/CONTRIBUTING.md" class="text-gray-400 hover:text-white transition-colors" target="_blank" rel="noopener">Contribute</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-xs">
        Vibe-coded with AI. No subscriptions were harmed in the making of this site.
      </p>
      <p class="text-gray-500 text-xs">
        <a href="https://github.com/davidklan-png/bountymon" class="hover:text-white transition-colors">Open Source</a> &middot; Built with Astro
      </p>
    </div>
  </div>
