---
const totalBounties = 8;
---

<header class="border-b border-gray-700 bg-gray-800/50 backdrop-blur-sm sticky top-0 z-10">
  <div class="max-w-6xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/mascot.png" alt="Bountymon Mascot" class="w-14 h-14 object-contain" />
        <div>
          <h1 class="text-2xl font-bold text-white">Bountymon</h1>
          <p class="text-sm text-gray-400">Kill subscriptions. Collect bounties. Build sovereignty.</p>
        </div>
      </div>
      <nav class="flex items-center gap-4">
        <a href="https://github.com/davidklan-png/bountymon" class="text-gray-400 hover:text-white transition-colors">
          GitHub
        </a>
      </nav>
    </div>
  </div>
</header>
