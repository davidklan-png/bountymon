---
interface Props {
  difficulty: string;
}

const { difficulty } = Astro.props;

const config: Record<string, { color: string; bg: string }> = {
  'easy': { color: 'text-green-400', bg: 'bg-green-500/10 border-green-500/20' },
  'moderate': { color: 'text-yellow-400', bg: 'bg-yellow-500/10 border-yellow-500/20' },
  'advanced': { color: 'text-red-400', bg: 'bg-red-500/10 border-red-500/20' },
};

const c = config[difficulty] || { color: 'text-gray-400', bg: 'bg-gray-500/10 border-gray-500/20' };
---

<span class:list={['inline-flex items-center rounded-full border text-xs px-2 py-0.5 font-medium', c.color, c.bg]}>
  {difficulty.charAt(0).toUpperCase() + difficulty.slice(1)}
</span>
