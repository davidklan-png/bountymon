---
import Layout from '../layouts/Layout.astro';
import SavingsCalculator from '../components/islands/SavingsCalculator';
---

<Layout title="Savings Calculator - Bountymon">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">Savings Calculator</h1>
      <p class="text-gray-400 text-lg max-w-2xl">
        Select the enterprise tools you currently pay for and see how much you could save by switching to open alternatives.
      </p>
    </div>

    <SavingsCalculator client:load />
  </div>
</Layout>
