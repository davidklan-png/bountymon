---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.data.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const articles = await getCollection('articles');
const related = articles
  .filter(a => a.data.slug !== article.data.slug && a.data.category === article.data.category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  'guide': 'Guide',
  'case-study': 'Case Study',
  'opinion': 'Opinion',
  'tutorial': 'Tutorial',
  'news': 'News',
};
---

<Layout title={`${article.data.title} - Bountymon Blog`} description={article.data.description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm mb-8">
      <a href="/blog" class="text-gray-400 hover:text-white transition-colors">Blog</a>
      <span class="text-gray-600 mx-2">/</span>
      <span class="text-white">{article.data.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-medium text-green-400 bg-green-500/10 border border-green-500/20 rounded-full px-2.5 py-1">
          {categoryLabels[article.data.category] || article.data.category}
        </span>
        <span class="text-sm text-gray-500">{article.data.read_time} min read</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">{article.data.title}</h1>
      <p class="text-lg text-gray-400 mb-4">{article.data.description}</p>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <span>By {article.data.author}</span>
        <span>{article.data.date}</span>
      </div>
    </header>

    <!-- Content -->
    <div class="prose prose-invert prose-green max-w-none
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-white [&_h2]:mt-10 [&_h2]:mb-4
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-white [&_h3]:mt-8 [&_h3]:mb-3
      [&_p]:text-gray-300 [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:space-y-2 [&_ul]:mb-4 [&_ol]:space-y-2 [&_ol]:mb-4
      [&_li]:text-gray-300
      [&_strong]:text-white [&_strong]:font-semibold
      [&_a]:text-green-400 [&_a:hover]:text-green-300 [&_a]:underline
      [&_code]:text-green-400 [&_code]:bg-gray-800 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm
      [&_pre]:bg-gray-900 [&_pre]:border [&_pre]:border-gray-800 [&_pre]:rounded-xl [&_pre]:p-4 [&_pre]:overflow-x-auto
      [&_pre_code]:bg-transparent [&_pre_code]:p-0
      [&_blockquote]:border-l-4 [&_blockquote]:border-green-500/30 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-gray-400
      [&_table]:w-full [&_table]:border-collapse
      [&_th]:bg-gray-800 [&_th]:text-white [&_th]:text-left [&_th]:p-3 [&_th]:text-sm [&_th]:font-semibold [&_th]:border [&_th]:border-gray-700
      [&_td]:p-3 [&_td]:text-sm [&_td]:text-gray-300 [&_td]:border [&_td]:border-gray-800
      [&_hr]:border-gray-800 [&_hr]:my-8">
      <Content />
    </div>

    <!-- Tags -->
    {article.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-10 pt-8 border-t border-gray-800">
        {article.data.tags.map(tag => (
          <span class="text-xs text-gray-400 bg-gray-800 border border-gray-700 rounded-full px-3 py-1">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Share CTA -->
    <div class="bg-gradient-to-r from-green-500/10 to-emerald-500/10 border border-green-500/20 rounded-xl p-6 mt-10 text-center">
      <p class="text-white font-semibold mb-2">Found this useful?</p>
      <p class="text-sm text-gray-400 mb-4">Share it with your team to start the conversation about SaaS savings.</p>
      <div class="flex justify-center gap-3">
        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.title)}&url=${encodeURIComponent(`https://bountymon.com/blog/${article.data.slug}`)}`}
          class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-white rounded-lg text-sm font-medium transition-colors border border-gray-700"
          target="_blank" rel="noopener">
          Share on X
        </a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://bountymon.com/blog/${article.data.slug}`)}`}
          class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-white rounded-lg text-sm font-medium transition-colors border border-gray-700"
          target="_blank" rel="noopener">
          Share on LinkedIn
        </a>
      </div>
    </div>
  </article>

  <!-- Related articles -->
  {related.length > 0 && (
    <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
      <h2 class="text-xl font-bold text-white mb-6">Related Articles</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {related.map(a => (
          <a href={`/blog/${a.data.slug}`} class="group bg-gray-900 border border-gray-800 rounded-xl p-4 hover:border-green-500/30 transition-all">
            <p class="text-xs text-gray-500 mb-2">{a.data.date}</p>
            <h3 class="font-semibold text-white group-hover:text-green-400 transition-colors text-sm leading-snug">
              {a.data.title}
            </h3>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
