---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featured = sorted.filter(a => a.data.featured);
const rest = sorted.filter(a => !a.data.featured);

const categoryLabels: Record<string, { label: string; color: string }> = {
  'guide': { label: 'Guide', color: 'text-blue-400 bg-blue-500/10 border-blue-500/20' },
  'case-study': { label: 'Case Study', color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
  'opinion': { label: 'Opinion', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
  'tutorial': { label: 'Tutorial', color: 'text-green-400 bg-green-500/10 border-green-500/20' },
  'news': { label: 'News', color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
};
---

<Layout title="Blog - Bountymon" description="Guides, case studies, and opinions on replacing enterprise software with vibe-coded alternatives.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">Blog</h1>
        <p class="text-gray-400 text-lg max-w-2xl">
          Guides, case studies, and opinions on replacing enterprise software with vibe-coded alternatives.
        </p>
      </div>
      <a href="/rss.xml" class="text-sm text-gray-400 hover:text-green-400 transition-colors shrink-0 flex items-center gap-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
        RSS Feed
      </a>
    </div>

    <!-- Featured articles -->
    {featured.length > 0 && (
      <div class="mb-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {featured.slice(0, 2).map((article, i) => {
            const cat = categoryLabels[article.data.category];
            return (
              <a href={`/blog/${article.data.slug}`} class:list={[
                'group block bg-gray-900 border border-gray-800 rounded-xl overflow-hidden hover:border-green-500/30 transition-all',
                i === 0 ? 'lg:col-span-2' : ''
              ]}>
                <div class="p-6 sm:p-8">
                  <div class="flex items-center gap-3 mb-4">
                    <span class:list={['text-xs font-medium rounded-full px-2.5 py-1 border', cat?.color || 'text-gray-400']}>
                      {cat?.label || article.data.category}
                    </span>
                    <span class="text-xs text-gray-500">{article.data.read_time} min read</span>
                    <span class="text-xs text-gray-500">{article.data.date}</span>
                  </div>
                  <h2 class:list={[
                    'font-bold text-white group-hover:text-green-400 transition-colors mb-3',
                    i === 0 ? 'text-2xl sm:text-3xl' : 'text-xl'
                  ]}>
                    {article.data.title}
                  </h2>
                  <p class="text-gray-400 leading-relaxed">{article.data.description}</p>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- All articles -->
    <div class="space-y-4 stagger-children">
      {(featured.length > 2 ? [...featured.slice(2), ...rest] : rest).map(article => {
        const cat = categoryLabels[article.data.category];
        return (
          <a href={`/blog/${article.data.slug}`} class="group block bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-green-500/30 transition-all">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class:list={['text-xs font-medium rounded-full px-2.5 py-1 border', cat?.color || 'text-gray-400']}>
                    {cat?.label || article.data.category}
                  </span>
                  <span class="text-xs text-gray-500">{article.data.read_time} min read</span>
                </div>
                <h2 class="text-lg font-semibold text-white group-hover:text-green-400 transition-colors mb-1">
                  {article.data.title}
                </h2>
                <p class="text-sm text-gray-400">{article.data.description}</p>
              </div>
              <span class="text-xs text-gray-500 shrink-0">{article.data.date}</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
