---
import Layout from '../../layouts/Layout.astro';
import DirectoryFilter from '../../components/islands/DirectoryFilter';
import { getCollection } from 'astro:content';

const categories = await getCollection('categories');
const alternatives = await getCollection('alternatives');

const categoryData = categories.map(cat => {
  const alts = alternatives.filter(a => a.data.category === cat.data.slug);
  const totalSavings = alts.reduce((sum, a) => sum + a.data.annual_cost_replaced, 0);
  const avgEnterpriseCost = cat.data.enterprise_examples.reduce((sum, e) => sum + e.annual_cost_per_seat, 0) / cat.data.enterprise_examples.length;
  return {
    name: cat.data.name,
    slug: cat.data.slug,
    icon: cat.data.icon,
    altCount: alts.length,
    totalSavings,
    avgEnterpriseCost,
    enterpriseExamples: cat.data.enterprise_examples.map(e => e.name).join(', '),
  };
}).sort((a, b) => b.totalSavings - a.totalSavings);

const totalAlternatives = alternatives.length;
const totalSavings = alternatives.reduce((sum, a) => sum + a.data.annual_cost_replaced, 0);
---

<Layout title="Directory - Bountymon">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-6 gap-4">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">Software Directory</h1>
        <p class="text-gray-400 text-lg max-w-2xl">
          Browse categories of enterprise software and discover open alternatives. Every category represents a moat waiting to be breached.
        </p>
      </div>
      <div class="flex gap-4 text-sm shrink-0">
        <div class="text-center">
          <p class="text-xl font-bold text-white">{totalAlternatives}</p>
          <p class="text-gray-500">Alternatives</p>
        </div>
        <div class="text-center">
          <p class="text-xl font-bold text-green-400">${totalSavings.toLocaleString()}</p>
          <p class="text-gray-500">Savings/yr</p>
        </div>
      </div>
    </div>

    <DirectoryFilter client:load categories={categoryData} />
  </div>
</Layout>
