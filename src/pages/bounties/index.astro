---
import Layout from '../../layouts/Layout.astro';
import BountyFilter from '../../components/islands/BountyFilter.tsx';
import { getCollection } from 'astro:content';

const bounties = await getCollection('bounties');

const sortedBounties = bounties.sort((a, b) => b.data.reward - a.data.reward);

const totalOpen = bounties.filter(b => b.data.status === 'open').reduce((sum, b) => sum + b.data.reward, 0);
const openCount = bounties.filter(b => b.data.status === 'open').length;
const activeCount = bounties.filter(b => b.data.status === 'claimed' || b.data.status === 'in-progress').length;
const completedCount = bounties.filter(b => b.data.status === 'delivered' || b.data.status === 'verified').length;

const repoBase = 'https://github.com/davidklan-png/bountymon';
const postBountyUrl = `${repoBase}/issues/new?title=${encodeURIComponent('[New Bounty] Replace <software name>')}&labels=new-bounty&body=${encodeURIComponent(`## New Bounty Proposal

### What enterprise software should be replaced?
<!-- Name and URL of the software -->

### Why?
<!-- What's wrong with the current option? Cost, lock-in, complexity? -->

### Annual cost per seat
<!-- e.g. $100/seat/year -->

### Number of seats
<!-- How many people use it? -->

### Proposed reward
<!-- What are you willing to put up? -->

### Requirements
<!-- Must-have features for the replacement -->
-
-
-

### Difficulty estimate
<!-- easy / moderate / hard / extreme -->

### Deadline suggestion
<!-- When should this be done by? -->
`)}`;

// Serialize bounty data for the island
const bountyItems = sortedBounties.map(b => ({
  slug: b.data.slug,
  title: b.data.title,
  description: b.data.description,
  replaces: b.data.replaces,
  status: b.data.status,
  difficulty: b.data.difficulty,
  reward: b.data.reward,
  annual_cost: b.data.annual_cost,
  seats: b.data.seats,
  requirements: b.data.requirements,
  deadline: b.data.deadline,
  claimed_by: b.data.claimed_by,
  tags: b.data.tags,
}));
---

<Layout title="Bounty Board - Bountymon">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">Bounty Board</h1>
        <p class="text-gray-400 text-lg max-w-2xl">
          Enterprise software has bounties on its head. Claim one by building an open alternative, or post a bounty for software you want replaced.
        </p>
      </div>
      <a
        href={postBountyUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-3 bg-amber-500 hover:bg-amber-400 text-gray-950 font-semibold rounded-lg transition-colors shrink-0"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Post a Bounty
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <div class="bg-gray-900 border border-amber-500/20 rounded-xl p-6 text-center">
        <p class="text-3xl font-bold text-amber-400">${totalOpen.toLocaleString()}</p>
        <p class="text-sm text-gray-400 mt-1">Open Rewards</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-center">
        <p class="text-3xl font-bold text-white">{openCount}</p>
        <p class="text-sm text-gray-400 mt-1">Open Bounties</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-center">
        <p class="text-3xl font-bold text-yellow-400">{activeCount}</p>
        <p class="text-sm text-gray-400 mt-1">In Progress</p>
      </div>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-center">
        <p class="text-3xl font-bold text-green-400">{completedCount}</p>
        <p class="text-sm text-gray-400 mt-1">Completed</p>
      </div>
    </div>

    <!-- How it works -->
    <div class="bg-gradient-to-r from-amber-500/5 to-orange-500/5 border border-amber-500/20 rounded-xl p-6 sm:p-8 mb-10">
      <h2 class="text-xl font-bold text-white mb-4">How Bounties Work</h2>
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-6">
        <div>
          <div class="w-8 h-8 bg-amber-500/20 rounded-full flex items-center justify-center text-amber-400 font-bold text-sm mb-3">1</div>
          <h3 class="text-white font-semibold mb-1">Post a Bounty</h3>
          <p class="text-sm text-gray-400">Identify enterprise software you want replaced. Set a reward and requirements.</p>
        </div>
        <div>
          <div class="w-8 h-8 bg-amber-500/20 rounded-full flex items-center justify-center text-amber-400 font-bold text-sm mb-3">2</div>
          <h3 class="text-white font-semibold mb-1">Hunters Claim</h3>
          <p class="text-sm text-gray-400">Developers claim bounties via GitHub issues. They outline their approach and timeline.</p>
        </div>
        <div>
          <div class="w-8 h-8 bg-amber-500/20 rounded-full flex items-center justify-center text-amber-400 font-bold text-sm mb-3">3</div>
          <h3 class="text-white font-semibold mb-1">Build in the Open</h3>
          <p class="text-sm text-gray-400">Progress is tracked with milestones. The community follows along and gives feedback.</p>
        </div>
        <div>
          <div class="w-8 h-8 bg-green-500/20 rounded-full flex items-center justify-center text-green-400 font-bold text-sm mb-3">4</div>
          <h3 class="text-white font-semibold mb-1">Collect the Bounty</h3>
          <p class="text-sm text-gray-400">When requirements are verified, the hunter collects the reward. Everyone wins.</p>
        </div>
      </div>
    </div>

    <!-- Filterable Bounty List -->
    <BountyFilter client:load bounties={bountyItems} />

    <!-- Bottom CTA -->
    <div class="mt-12 bg-gray-900 border border-gray-800 rounded-xl p-8 text-center">
      <h2 class="text-xl font-bold text-white mb-3">Don't see what you need?</h2>
      <p class="text-gray-400 mb-6">Post a bounty for the enterprise software you want replaced. Set the reward, define requirements, and let the community build it.</p>
      <a
        href={postBountyUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 bg-amber-500 hover:bg-amber-400 text-gray-950 font-semibold rounded-lg transition-colors"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Post a Bounty
      </a>
    </div>
  </div>
</Layout>
